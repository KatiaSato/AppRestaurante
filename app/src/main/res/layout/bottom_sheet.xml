<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/bottom_sheet_container"
    android:layout_width="match_parent"
    android:layout_height="480dp"
    android:background="@android:color/transparent">
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="480dp"
        android:background="@drawable/bottom_sheet_bacground">

    <TextView
        android:id="@+id/text1_sheet"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/inter"
        android:layout_marginStart="16dp"
        android:layout_marginTop="25dp"/>
    <TextView
        android:id="@+id/text2_sheet"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/fraunces_semibold"
        android:layout_below="@+id/text1_sheet"
        android:layout_marginStart="16dp"
        android:textSize="20dp"/>
    <TextView
        android:id="@+id/nome"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Nome *"
        android:fontFamily="@font/inter"
        android:layout_below="@+id/text2_sheet"
        android:layout_marginStart="16dp"
        android:layout_marginTop="15dp"/>

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/nomeRestauranteImputLayout"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_below="@+id/nome"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        app:boxCornerRadiusTopStart="20dp"
        app:boxCornerRadiusBottomEnd="20dp"
        app:boxCornerRadiusBottomStart="20dp"
        app:boxCornerRadiusTopEnd="20dp"
        android:gravity="bottom"
        android:outlineSpotShadowColor="@color/terracota"
        android:hint="Ex: cantina da Esquina">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/nomeRestauranteImput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="text"
             />
    </com.google.android.material.textfield.TextInputLayout>
    <TextView
        android:id="@+id/textopicional"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Resumo (opicional)"
        android:layout_marginStart="16dp"
        android:layout_below="@+id/nomeRestauranteImputLayout"
        android:layout_marginTop="18dp"/>

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/resumoImputLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@+id/textopicional"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/resumoRestauranteInput"
            android:layout_width="match_parent"
            android:layout_height="100dp"
            android:hint="Pratos favoritos, dicas, endereço..."
            android:gravity="top"
            android:inputType="text"/>
    </com.google.android.material.textfield.TextInputLayout>
    <TextView
        android:id="@+id/nota"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Nota (opicional)"
        android:layout_below="@+id/resumoImputLayout"
        android:layout_marginTop="12dp"
        android:layout_marginStart="16dp"/>

    <RatingBar
        android:id="@+id/ratingBar"
        android:layout_width="wrap_content"
        android:layout_height="42dp"
        android:layout_below="@+id/nota"
        android:layout_marginStart="16dp"
        android:numStars="5" />

    <Button
        android:id="@+id/adicionar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Adiconar na lista"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_below="@+id/ratingBar"
        android:layout_marginTop="16dp"
        />

    </RelativeLayout>
</RelativeLayout>